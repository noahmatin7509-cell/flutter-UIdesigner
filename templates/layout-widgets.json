{
  "widgets": [
    {
      "type": "Column",
      "name": "Column Layout",
      "description": "Arrange widgets vertically",
      "props": {
        "mainAxisAlignment": "start",
        "crossAxisAlignment": "start"
      }
    },
    {
      "type": "Row",
      "name": "Row Layout",
      "description": "Arrange widgets horizontally",
      "props": {
        "mainAxisAlignment": "start",
        "crossAxisAlignment": "start"
      }
    },
    {
      "type": "Stack",
      "name": "Stack Layout",
      "description": "Overlap widgets",
      "props": {
        "alignment": "topLeft"
      }
    },
    {
      "type": "Container",
      "name": "Container",
      "description": "Container with styling",
      "props": {
        "width": 100,
        "height": 100,
        "color": "#ffffff",
        "padding": 8
      }
    },
    {
      "type": "Scaffold",
      "name": "Scaffold",
      "description": "Basic page structure",
      "props": {
        "appBar": true,
        "bottomNavigationBar": false
      }
    }
  ]
}